{
  "name": "card-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,socket -c blue,green \"npm:dev:next\" \"npm:dev:socket\"",
    "dev:next": "next dev",
    "dev:socket": "tsx watch server/index.ts",
    "build": "next build",
    "start": "next start",
    "start:socket": "tsx server/index.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
